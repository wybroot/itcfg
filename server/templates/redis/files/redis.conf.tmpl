# Redis 配置文件
# 由 ITCFG 配置中台自动生成

bind {{.BIND_ADDRESS}}
port {{.PORT}}
protected-mode yes
tcp-backlog {{.TCP_BACKLOG}}
timeout {{.TIMEOUT}}
tcp-keepalive 300
daemonize no
supervised no
pidfile /var/run/redis_6379.pid
loglevel {{.LOG_LEVEL}}
logfile "{{.LOG_DIR}}/redis.log"
databases {{.DATABASES}}

{{if .REQUIREPASS}}
requirepass {{.REQUIREPASS}}
{{end}}

# 持久化 - RDB
{{range $i, $policy := split .SAVE_INTERVAL " "}}
save {{$policy}}
{{end}}
stop-writes-on-bgsave-error yes
rdbcompression yes
dbfilename dump.rdb
dir /data

# 持久化 - AOF
appendonly {{.APPENDONLY}}
appendfsync {{.APPENDFSYNC}}
no-appendfsync-on-rewrite no
auto-aof-rewrite-percentage 100
auto-aof-rewrite-min-size 64mb

# 内存管理
maxmemory {{.MAXMEMORY}}
maxmemory-policy {{.MAXMEMORY_POLICY}}

# 慢查询日志
slowlog-log-slower-than 10000
slowlog-max-len 128

# 客户端
maxclients 10000