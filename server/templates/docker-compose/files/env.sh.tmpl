# ============================================
# ITCFG 全局环境变量
# 由配置中台自动生成，请勿手动修改
# ============================================

# 项目配置
export PROJECT_NAME={{.PROJECT_NAME}}
export TZ={{.TIMEZONE}}

# 数据与日志目录
export DATA_BASE_DIR={{.DATA_BASE_DIR}}
export LOG_BASE_DIR={{.LOG_BASE_DIR}}

# Nginx
export NGINX_HTTP_PORT=${NGINX_HTTP_PORT:-80}
export NGINX_HTTPS_PORT=${NGINX_HTTPS_PORT:-443}

# Java 应用
export JAVA_APP_PORT=${JAVA_APP_PORT:-8080}
export JAVA_OPTS=${JAVA_OPTS:--Xms512m -Xmx1g}

# PostgreSQL
export POSTGRES_PORT=${POSTGRES_PORT:-5432}
export POSTGRES_DB=${POSTGRES_DB:-itcfg}
export POSTGRES_USER=${POSTGRES_USER:-itcfg}
export POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-itcfg123}

# Redis
export REDIS_PORT=${REDIS_PORT:-6379}

# MinIO
export MINIO_API_PORT=${MINIO_API_PORT:-9000}
export MINIO_CONSOLE_PORT=${MINIO_CONSOLE_PORT:-9001}

# MongoDB
export MONGO_PORT=${MONGO_PORT:-27017}

# Elasticsearch
export ES_HTTP_PORT=${ES_HTTP_PORT:-9200}
export ES_TRANSPORT_PORT=${ES_TRANSPORT_PORT:-9300}
export ES_JAVA_OPTS=${ES_JAVA_OPTS:--Xms1g -Xmx1g}

# OnlyOffice
export ONLYOFFICE_PORT=${ONLYOFFICE_PORT:-8083}

# Collabora Code
export COLLABORA_PORT=${COLLABORA_PORT:-9980}

# File Viewer
export FILE_VIEWER_PORT=${FILE_VIEWER_PORT:-8081}

# FileCodeBox
export FILECODEBOX_PORT=${FILECODEBOX_PORT:-8082}

# Etcd
export ETCD_CLIENT_PORT=${ETCD_CLIENT_PORT:-2379}
export ETCD_PEER_PORT=${ETCD_PEER_PORT:-2380}

# Kafka
export KAFKA_PORT=${KAFKA_PORT:-9092}